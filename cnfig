local function CreateTabButton(name, icon, position)
    local Btn = Create("TextButton", {
        Name = name .. "Tab",
        Size = UDim2.new(1, -6, 0, 32),
        Position = UDim2.new(0, 3, 0, position),
        BackgroundColor3 = (name == ActiveTab) and CONFIG.Colors.Primary or CONFIG.Colors.White,
        BackgroundTransparency = (name == ActiveTab) and 0.2 or 0.9,
        Text = "",
        Parent = Sidebar
    })
    AddCorner(Btn, 4)

    local TabIcon = Create("ImageLabel", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 8, 0.5, -8),
        BackgroundTransparency = 1,
        Image = icon,
        ImageColor3 = (name == ActiveTab) and CONFIG.Colors.White or CONFIG.Colors.TextSecondary,
        Parent = Btn
    })

    local TabText = Create("TextLabel", {
        Size = UDim2.new(1, -28, 1, 0),
        Position = UDim2.new(0, 28, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = (name == ActiveTab) and CONFIG.Colors.White or CONFIG.Colors.TextPrimary,
        TextSize = 11,
        Font = Enum.Font.GothamSemibold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Btn
    })

    Btn.MouseEnter:Connect(function()
        if name ~= ActiveTab then
            Tween(Btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.7})
            Tween(TabIcon, TweenInfo.new(0.2), {ImageColor3 = CONFIG.Colors.Primary})
            Tween(TabText, TweenInfo.new(0.2), {TextColor3 = CONFIG.Colors.TitlePink})
        end
    end)

    Btn.MouseLeave:Connect(function()
        if name ~= ActiveTab then
            Tween(Btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.9})
            Tween(TabIcon, TweenInfo.new(0.2), {ImageColor3 = CONFIG.Colors.TextSecondary})
            Tween(TabText, TweenInfo.new(0.2), {TextColor3 = CONFIG.Colors.TextPrimary})
        end
    end)

    return {Button = Btn, Icon = TabIcon, Text = TabText, Name = name}
end

