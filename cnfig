local showHero = false

local function CreateHighlight()
	for _, v in pairs(Players:GetPlayers()) do
		if v ~= LP and v.Character then
			local h = v.Character:FindFirstChild("Highlight")
			if not h then
				h = Instance.new("Highlight")
				h.Parent = v.Character
			end
		end
	end
end

local function IsAlive(player)
	if not roles or not roles[player.Name] then return false end
	local data = roles[player.Name]
	return not data.Killed and not data.Dead
end

local function HasGun(player)
	if not roles or not roles[player.Name] then return false end
	return roles[player.Name].HasGun == true
end

local function GetRole(player)
	if not roles or not roles[player.Name] then
		return "Unknown"
	end

	local data = roles[player.Name]

	if data.Role == "Murderer" then
		return "Murderer"
	end

	if data.Role == "Sheriff" then
		return "Sheriff"
	end

	if data.Role == "Hero" or data.HasGun then
		return "Hero"
	end

	return "Innocent"
end

local function ApplyColor(highlight, role)
	highlight.Enabled = true

	if role == "Murderer" then
		highlight.FillColor = Color3.fromRGB(225, 0, 0)

	elseif role == "Sheriff" then
		highlight.FillColor = Color3.fromRGB(0, 0, 225)

	elseif role == "Hero" then
		highlight.FillColor = Color3.fromRGB(255, 250, 0)

	elseif role == "Innocent" then
		highlight.FillColor = Color3.fromRGB(0, 225, 0)

	else
		highlight.FillColor = Color3.fromRGB(120, 120, 120) -- GRAY DEFAULT
	end
end

local function UpdateHighlights()
	for _, v in pairs(Players:GetPlayers()) do
		if v ~= LP and v.Character then
			local highlight = v.Character:FindFirstChild("Highlight")
			if highlight then
				local role = GetRole(v)

				highlight.Enabled = false

				if role == "Murderer" and showMurderer then
					ApplyColor(highlight, role)

				elseif role == "Sheriff" and showSheriff and IsAlive(v) then
					ApplyColor(highlight, role)

				elseif role == "Hero" and showHero and IsAlive(v) then
					ApplyColor(highlight, role)

				elseif role == "Innocent" and showInnocent then
					ApplyColor(highlight, role)

				elseif highlightEnabled then
					ApplyColor(highlight, "Unknown")
				end
			end
		end
	end
end

