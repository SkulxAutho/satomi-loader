            end
        else
            autoThrowEnabled = false
            updateUI(false)
            stopAutoThrow()
        end
    end)

    task.spawn(function()
        while true do
            if autoThrowEnabled and not IsMurderer() then
                autoThrowEnabled = false
                updateUI(false)
                stopAutoThrow()
            end
            task.wait(1)
        end
    end)

    updateUI(false)
end

