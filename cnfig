local function GetCurrentRole()
    local success, roles = pcall(function()
        local getData = ReplicatedStorage:FindFirstChild("GetPlayerData", true)
        if getData then
            return getData:InvokeServer()
        end
        return nil
    end)
    
    if success and roles then
        for playerName, data in pairs(roles) do
            if playerName == LocalPlayer.Name then
                return data.Role or "Unknown"
            end
        end
    end
    return "Unknown"
end

