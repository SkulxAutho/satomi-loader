local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local autoShootEnabled = false
local shootCooldown = 0.8
local maxDistance = 100
local canShoot = true

local raycastParams = RaycastParams.new()
raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

local function getMurderer()
	for _, v in pairs(Players:GetPlayers()) do
		if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
			if v.Character:FindFirstChild("Knife") or v.Backpack:FindFirstChild("Knife") then
				return v.Character.HumanoidRootPart
			end
		end
	end
	return nil
end

local function getPredictedPosition(hrp)
	if not hrp then return nil end
	local velocity = hrp.Velocity
	local position = hrp.Position
	local predictedPos = position + (velocity * 0.02)
	return predictedPos + Vector3.new(0, 1.2, 0)
end

local function isMurdererVisible(hrp)
	if not hrp then return false end

	local char = LocalPlayer.Character
	local myHRP = char and char:FindFirstChild("HumanoidRootPart")
	if not myHRP then return false end

	if (myHRP.Position - hrp.Position).Magnitude > maxDistance then
		return false
	end

	local camera = workspace.CurrentCamera
	local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
	if not onScreen then return false end

	local viewportSize = camera.ViewportSize
	if screenPos.X < 0 or screenPos.X > viewportSize.X then return false end
	if screenPos.Y < 0 or screenPos.Y > viewportSize.Y then return false end

	local origin = camera.CFrame.Position
	local targetPos = hrp.Position + Vector3.new(0, 1.2, 0)
	local direction = (targetPos - origin).Unit
	local distance = (targetPos - origin).Magnitude

	local result = Workspace:Raycast(origin, direction * distance, raycastParams)

	if result then
		local model = result.Instance:FindFirstAncestorOfClass("Model")
		if model and model:FindFirstChild("Humanoid") then
			local hitPlayer = Players:GetPlayerFromCharacter(model)
			local murdererPlayer = Players:GetPlayerFromCharacter(hrp.Parent)
			if hitPlayer == murdererPlayer then
				return true
			end
		end
		return false
	end

	return true
end

local function autoShoot()
	if not autoShootEnabled or not canShoot then return end

	local char = LocalPlayer.Character
	if not char then return end

	local gun = char:FindFirstChild("Gun") or (LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild("Gun"))
	if not gun or not gun:FindFirstChild("Shoot") then return end

	local murdererHRP = getMurderer()
	if not murdererHRP then return end

	if not isMurdererVisible(murdererHRP) then return end

	local origin = workspace.CurrentCamera.CFrame.Position
	local targetPos = getPredictedPosition(murdererHRP)

	if not targetPos then return end

	local aimCFrame = CFrame.new(origin, targetPos)

	gun.Shoot:FireServer(aimCFrame, CFrame.new(targetPos))

	canShoot = false
	task.delay(shootCooldown, function()
		canShoot = true
	end)
end

RunService.RenderStepped:Connect(function()
	pcall(autoShoot)
end)

