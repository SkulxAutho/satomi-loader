-- Tab Switching
local function SwitchTab(newTab, showBack)
    if newTab == ActiveTab then return end
    PlayClickSound()
    local prevTab = Tabs[ActiveTab]
    Tween(prevTab.Button, TweenInfo.new(0.2), {BackgroundTransparency = 0.9})
    Tween(prevTab.Icon, TweenInfo.new(0.2), {ImageColor3 = CONFIG.Colors.TextSecondary})
    Tween(prevTab.Text, TweenInfo.new(0.2), {TextColor3 = CONFIG.Colors.TextPrimary})
    ContentAreas[ActiveTab].Frame.Visible = false
    PreviousTab = ActiveTab
    ActiveTab = newTab
    local newTabData = Tabs[newTab]
    Tween(newTabData.Button, TweenInfo.new(0.2), {BackgroundTransparency = 0.2})
    Tween(newTabData.Icon, TweenInfo.new(0.2), {ImageColor3 = CONFIG.Colors.White})
    Tween(newTabData.Text, TweenInfo.new(0.2), {TextColor3 = CONFIG.Colors.White})
    ContentAreas[newTab].Frame.Visible = true
    BackButton.Visible = showBack or false
    TitleArea.Visible = not (showBack or false)
end

BackButton.MouseButton1Click:Connect(function()
    PlayClickSound()
    if PreviousTab then
        SwitchTab(PreviousTab, false)
    end
end)

